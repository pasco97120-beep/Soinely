generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Service {
  id         Int      @id @default(autoincrement())
  nom        String
  code       String   @unique
  etage      Int?
  aile       String?
  createdAt  DateTime @default(now())

  chambres    Chambre[]
  infirmiers  Infirmier[]
  admissions  Admission[]
  tournees    Tournee[]
}

model Chambre {
  id          Int      @id @default(autoincrement())
  serviceId   Int
  numero      String
  nombreLits  Int      @default(1)
  type        String   @default("simple")

  service Service @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  lits    Lit[]

  @@unique([serviceId, numero])
}

model Lit {
  id         Int    @id @default(autoincrement())
  chambreId  Int
  numeroLit  String
  statut     String @default("libre")

  chambre    Chambre     @relation(fields: [chambreId], references: [id], onDelete: Cascade)
  admissions Admission[]
}

model Infirmier {
  id            Int      @id @default(autoincrement())
  matricule     String   @unique
  nom           String
  prenom        String
  sexe          String   @default("F")
  email         String?  @unique
  telephone     String?
  specialite    String?
  grade         String   @default("infirmier")
  serviceId     Int?
  actif         Boolean  @default(true)
  dateEmbauche  DateTime?
  createdAt     DateTime @default(now())

  service            Service?          @relation(fields: [serviceId], references: [id])
  utilisateur        Utilisateur?
  tournees           Tournee[]
  constantesVitales  ConstanteVitale[]
  soins              Soin[]
  transmissions      Transmission[]
  alertes            Alerte[]
}

model Utilisateur {
  id                 Int       @id @default(autoincrement())
  infirmierId        Int       @unique
  username           String    @unique
  passwordHash       String
  role               String    @default("infirmier")
  derniereConnexion  DateTime?
  actif              Boolean   @default(true)
  createdAt          DateTime  @default(now())

  infirmier Infirmier @relation(fields: [infirmierId], references: [id], onDelete: Cascade)
}

model Patient {
  id                  Int       @id @default(autoincrement())
  numeroDossier       String    @unique
  nom                 String
  prenom              String
  sexe                String
  dateNaissance       DateTime
  telephone           String?
  email               String?
  adresse             String?
  contactUrgenceNom   String?
  contactUrgenceTel   String?
  contactUrgenceLien  String?
  groupeSanguin       String    @default("inconnu")
  allergies           String?
  antecedents         String?
  notes               String?
  createdAt           DateTime  @default(now())

  admissions Admission[]
}

model Admission {
  id                   Int       @id @default(autoincrement())
  patientId            Int
  serviceId            Int
  litId                Int?
  medecinResponsable   String?
  dateAdmission        DateTime
  dateSortiePrevue     DateTime?
  dateSortieReelle     DateTime?
  motifAdmission       String
  diagnosticPrincipal  String?
  statut               String    @default("en_cours")
  createdAt            DateTime  @default(now())

  patient            Patient           @relation(fields: [patientId], references: [id])
  service            Service           @relation(fields: [serviceId], references: [id])
  lit                Lit?              @relation(fields: [litId], references: [id])
  prescriptions       Prescription[]
  constantesVitales   ConstanteVitale[]
  tourneePatients     TourneePatient[]
  transmissions       Transmission[]
  alertes             Alerte[]
}

model Prescription {
  id                 Int       @id @default(autoincrement())
  admissionId        Int
  medecin            String
  datePrescription   DateTime
  dateFin            DateTime?
  statut             String    @default("active")

  admission   Admission             @relation(fields: [admissionId], references: [id], onDelete: Cascade)
  medicaments PrescriptionMedicament[]
}

model PrescriptionMedicament {
  id                   Int     @id @default(autoincrement())
  prescriptionId       Int
  medicamentNom        String
  dosage               String
  forme                String?
  frequence            String
  voieAdministration   String  @default("orale")
  heurePrise           String?
  dureeJours           Int?
  instructions         String?

  prescription Prescription @relation(fields: [prescriptionId], references: [id], onDelete: Cascade)
  soins        Soin[]
}

model ConstanteVitale {
  id                     Int      @id @default(autoincrement())
  admissionId            Int
  infirmierId            Int
  dateMesure             DateTime
  tensionSystolique      Int?
  tensionDiastolique     Int?
  frequenceCardiaque     Int?
  frequenceRespiratoire  Int?
  temperature            Float?
  saturationO2           Float?
  glycemie               Float?
  poids                  Float?
  notes                  String?

  admission Admission @relation(fields: [admissionId], references: [id], onDelete: Cascade)
  infirmier Infirmier @relation(fields: [infirmierId], references: [id])
}

model Tournee {
  id            Int      @id @default(autoincrement())
  serviceId     Int
  infirmierId   Int
  dateTournee   DateTime
  heureDebut    String?
  heureFin      String?
  quart         String
  statut        String   @default("planifiee")
  notes         String?

  service   Service          @relation(fields: [serviceId], references: [id])
  infirmier Infirmier        @relation(fields: [infirmierId], references: [id])
  patients  TourneePatient[]

  @@unique([serviceId, infirmierId, dateTournee, quart])
}

model TourneePatient {
  id            Int      @id @default(autoincrement())
  tourneeId     Int
  admissionId   Int
  ordreVisite   Int?
  statutVisite  String   @default("en_attente")
  heureVisite   String?
  notesVisite   String?

  tournee   Tournee   @relation(fields: [tourneeId], references: [id], onDelete: Cascade)
  admission Admission @relation(fields: [admissionId], references: [id], onDelete: Cascade)
  soins     Soin[]

  @@unique([tourneeId, admissionId])
}

model Soin {
  id                          Int       @id @default(autoincrement())
  tourneePatientId            Int
  infirmierId                 Int
  typeSoin                    String
  categorie                   String    @default("autre")
  heureRealisation            DateTime
  realise                     Boolean   @default(false)
  motifNonRealise             String?
  observations                String?
  prescriptionMedicamentId    Int?

  tourneePatient          TourneePatient           @relation(fields: [tourneePatientId], references: [id], onDelete: Cascade)
  infirmier                Infirmier                @relation(fields: [infirmierId], references: [id])
  prescriptionMedicament   PrescriptionMedicament?  @relation(fields: [prescriptionMedicamentId], references: [id])
}

model Transmission {
  id                Int      @id @default(autoincrement())
  admissionId       Int
  infirmierId       Int
  dateTransmission  DateTime @default(now())
  quart             String
  contenu           String
  priorite          String   @default("normale")
  lue               Boolean  @default(false)

  admission Admission @relation(fields: [admissionId], references: [id], onDelete: Cascade)
  infirmier Infirmier @relation(fields: [infirmierId], references: [id])
}

model Alerte {
  id               Int       @id @default(autoincrement())
  admissionId      Int?
  infirmierId      Int?
  typeAlerte       String
  message          String
  priorite         String    @default("normale")
  statut           String    @default("non_lue")
  dateAlerte       DateTime  @default(now())
  dateTraitement   DateTime?

  admission Admission? @relation(fields: [admissionId], references: [id])
  infirmier Infirmier? @relation(fields: [infirmierId], references: [id])
}

// ============================================================
// SOINELY — bibliothèque IDEL (landing page produit)
// ============================================================

model IdelUser {
  id            Int      @id @default(autoincrement())
  email         String   @unique
  passwordHash  String
  nom           String
  prenom        String
  cabinetId     Int?
  cabinetRole   String?
  createdAt     DateTime @default(now())

  cabinet       Cabinet? @relation(fields: [cabinetId], references: [id])
  favoris       Favori[]
  consultations Consultation[]
  signalements  Signalement[]
  clients       Client[]
}

model Cabinet {
  id              Int      @id @default(autoincrement())
  nom             String
  codeInvitation  String   @unique
  createdAt       DateTime @default(now())

  membres   IdelUser[]
  partages  CabinetFiche[]
}

model Hub {
  id          Int    @id @default(autoincrement())
  slug        String @unique
  nom         String
  description String
  icone       String
  ordre       Int    @default(0)

  fiches Fiche[]
}

model Fiche {
  id           Int      @id @default(autoincrement())
  hubId        Int
  slug         String
  titre        String
  resume       String
  contenu      String
  // Modèles concrets prêts à l'emploi (ex. courriers de liaison) — un ou plusieurs blocs
  // séparés par des titres "## Titre", affichés avec copie en un clic sur la fiche.
  exemple      String?
  tags         String   @default("")
  // Niveau de priorité clinique SCR-003 : information | vigilance | action | urgente
  priorite     String   @default("information")
  // Statut de validation éditoriale — Trust Center™ (Master Book Vol.6 Ch.2) :
  // valide | en_revision | a_mettre_a_jour | archive
  statut       String   @default("en_revision")
  dureeLecture Int      @default(3)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  hub           Hub            @relation(fields: [hubId], references: [id], onDelete: Cascade)
  favoris       Favori[]
  missions      MissionFiche[]
  cabinets      CabinetFiche[]
  dailyTips     DailyTip[]
  consultations Consultation[]
  signalements  Signalement[]

  @@unique([hubId, slug])
}

model Mission {
  id          Int    @id @default(autoincrement())
  slug        String @unique
  titre       String
  description String
  icone       String
  ordre       Int    @default(0)

  fiches MissionFiche[]
}

model MissionFiche {
  id        Int @id @default(autoincrement())
  missionId Int
  ficheId   Int
  ordre     Int @default(0)

  mission Mission @relation(fields: [missionId], references: [id], onDelete: Cascade)
  fiche   Fiche   @relation(fields: [ficheId], references: [id], onDelete: Cascade)

  @@unique([missionId, ficheId])
}

model Favori {
  id         Int      @id @default(autoincrement())
  idelUserId Int
  ficheId    Int
  createdAt  DateTime @default(now())

  idelUser IdelUser @relation(fields: [idelUserId], references: [id], onDelete: Cascade)
  fiche    Fiche    @relation(fields: [ficheId], references: [id], onDelete: Cascade)

  @@unique([idelUserId, ficheId])
}

// Historique de consultation — alimente "Reprendre mon activité" (SCR-001) et
// "Historique" (Profil, Master Book Vol.3 Ch.6). Une ligne par (utilisateur, fiche),
// mise à jour à chaque nouvelle visite plutôt qu'un journal illimité.
model Consultation {
  id          Int      @id @default(autoincrement())
  idelUserId  Int
  ficheId     Int
  consultedAt DateTime @default(now())

  idelUser IdelUser @relation(fields: [idelUserId], references: [id], onDelete: Cascade)
  fiche    Fiche    @relation(fields: [ficheId], references: [id], onDelete: Cascade)

  @@unique([idelUserId, ficheId])
}

// Signalements — Trust Center™ (Master Book Vol.6 Ch.2) : "Chaque utilisateur peut
// contribuer à l'amélioration de la plateforme." Aucune UI d'administration pour l'instant :
// les signalements sont capturés et consultables directement en base par l'équipe éditoriale.
model Signalement {
  id         Int      @id @default(autoincrement())
  ficheId    Int
  idelUserId Int
  type       String // erreur | amelioration | lien_inactif | autre
  message    String
  statut     String   @default("nouveau") // nouveau | traite
  createdAt  DateTime @default(now())

  fiche    Fiche    @relation(fields: [ficheId], references: [id], onDelete: Cascade)
  idelUser IdelUser @relation(fields: [idelUserId], references: [id], onDelete: Cascade)
}

model CabinetFiche {
  id        Int      @id @default(autoincrement())
  cabinetId Int
  ficheId   Int
  createdAt DateTime @default(now())

  cabinet Cabinet @relation(fields: [cabinetId], references: [id], onDelete: Cascade)
  fiche   Fiche   @relation(fields: [ficheId], references: [id], onDelete: Cascade)

  @@unique([cabinetId, ficheId])
}

// Dossier client IDEL (patientèle de la tournée en libéral) — distinct du modèle
// Patient hospitalier ci-dessus. Un client appartient à l'IDEL qui l'a créé.
model Client {
  id             Int       @id @default(autoincrement())
  idelUserId     Int
  nom            String
  prenom         String
  dateNaissance  DateTime?
  adresse        String?
  telephone      String?
  notes          String?
  createdAt      DateTime  @default(now())

  idelUser  IdelUser         @relation(fields: [idelUserId], references: [id], onDelete: Cascade)
  documents ClientDocument[]
}

// Pièce du dossier client capturée au téléphone (ordonnance, carte Vitale, etc.).
// Stockée directement en base (data URL) : pas d'infrastructure de stockage fichiers
// supplémentaire à ce stade — à faire évoluer vers un stockage objet si le volume grossit.
model ClientDocument {
  id        Int      @id @default(autoincrement())
  clientId  Int
  type      String // prescription | carte_vitale | autre
  label     String?
  dataUrl   String
  createdAt DateTime @default(now())

  client Client @relation(fields: [clientId], references: [id], onDelete: Cascade)
}

model DailyTip {
  id      Int    @id @default(autoincrement())
  type    String @default("recommandation")
  titre   String
  contenu String
  ficheId Int?
  ordre   Int    @default(0)

  fiche Fiche? @relation(fields: [ficheId], references: [id])
}
